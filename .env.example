APP_NAME=roadbogo-api
APP_ENV=local
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
INTERNAL_API_V1_PREFIX=/api/internal/v1
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change-me
DB_NAME=roadbogo

# MinIO
MINIO_ENDPOINT=192.168.0.101:9000
MINIO_ACCESS_KEY=change-me
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=roadbogo
MINIO_SECURE=false

# Authentication
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_JWT_SECRET_KEY=change-me
AUTH_JWT_ALGORITHM=HS256
AUTH_JWT_ISSUER=roadbogo-api
AUTH_JWT_AUDIENCE=roadbogo-web
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=30
AUTH_REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_REFRESH_COOKIE_NAME=roadbogo_refresh_token
