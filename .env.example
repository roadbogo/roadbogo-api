APP_NAME=roadbogo-api
APP_ENV=local
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
INTERNAL_API_V1_PREFIX=/api/internal/v1
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO

# AI inference server
AI_SERVER_BASE_URL=http://192.168.0.102:8010
AI_SERVER_INTERNAL_API_V1_PREFIX=/api/internal/v1
AI_INTERNAL_API_KEY=
AI_INFERENCE_TIMEOUT_SECONDS=30

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change-me
DB_NAME=roadbogo

# MinIO
MINIO_ENDPOINT=192.168.0.101:9000
MINIO_ACCESS_KEY=change-me
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=roadbogo
MINIO_SECURE=false

# Authentication
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_JWT_SECRET_KEY=change-me
AUTH_JWT_ALGORITHM=HS256
AUTH_JWT_ISSUER=roadbogo-api
AUTH_JWT_AUDIENCE=roadbogo-web
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=30
AUTH_REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_REFRESH_COOKIE_NAME=roadbogo_refresh_token

# Phone encryption
# Dedicated Fernet key used only to encrypt phone numbers.
# Do not reuse AUTH_JWT_SECRET_KEY and never commit a real key.
AUTH_PHONE_ENCRYPTION_KEY=

# Password reset
# Frontend URL used to create the password reset link.
FRONTEND_BASE_URL=http://localhost:3000

# Password reset link lifetime in minutes.
AUTH_PASSWORD_RESET_EXPIRE_MINUTES=30

# Local/test development helper.
# When true in local or test, the API may include debug_reset_token and
# debug_reset_url so password reset can be tested without SMTP.
# Keep this false when SMTP is configured and always keep it false in production.
AUTH_PASSWORD_RESET_DEBUG_RESPONSE=false

# SMTP
# Configure these values to send real password reset emails.
# SMTP_HOST and SMTP_FROM_EMAIL are required for delivery.
# SMTP_USERNAME and SMTP_PASSWORD are only needed when authentication is required.
# SMTP_USE_TLS=true enables STARTTLS.
# Never commit real SMTP credentials or passwords.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
